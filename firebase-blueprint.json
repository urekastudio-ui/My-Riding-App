{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User specific settings and global stats",
      "type": "object",
      "properties": {
        "odometer": {
          "type": "number",
          "description": "Total distance traveled in meters"
        },
        "emergencyContact": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" }
          },
          "required": ["name", "phone"]
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["odometer"]
    },
    "MaintenanceRecord": {
      "title": "Maintenance Record",
      "description": "Record of motorcycle maintenance",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "Type of maintenance (e.g., Oil Change, Tire Replacement)"
        },
        "mileage": {
          "type": "number",
          "description": "Odometer reading at time of maintenance"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "cost": {
          "type": "number",
          "description": "Cost of maintenance"
        },
        "notes": {
          "type": "string"
        }
      },
      "required": ["type", "mileage", "date", "cost"]
    },
    "RideSession": {
      "title": "Ride Session",
      "description": "Record of a specific riding session",
      "type": "object",
      "properties": {
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "distance": { "type": "number", "description": "Distance in meters" },
        "startOdo": { "type": "number" },
        "endOdo": { "type": "number" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["startTime", "endTime", "distance"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile with odometer and settings"
    },
    "users/{userId}/maintenance/{recordId}": {
      "schema": "MaintenanceRecord",
      "description": "Collection of maintenance records for the user"
    },
    "users/{userId}/sessions/{sessionId}": {
      "schema": "RideSession",
      "description": "Historical riding sessions"
    }
  }
}
